# Local OSS substrate env for reporium-events.
# Copy to .env (the smoke script and compose read these).
# All values point at LOCAL emulators only. No secrets, no cloud credentials.

# Project id used by both emulators and the publisher.
PUBSUB_PROJECT_ID=perditio-platform
FIRESTORE_PROJECT_ID=perditio-platform

# These two vars are read by the google-cloud-* client libraries.
# When set, the libraries talk to the local emulators instead of real GCP.
PUBSUB_EMULATOR_HOST=localhost:8085
FIRESTORE_EMULATOR_HOST=localhost:8086

# Topic and subscription used by the smoke test (matches publisher defaults).
PUBSUB_TOPIC=reporium-events
PUBSUB_SUBSCRIPTION=reporium-events-smoke
